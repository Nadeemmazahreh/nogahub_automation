# ========================================
# NogaHub Automation - Environment Variables
# ========================================

# --------------------------------------------
# SUPABASE CONFIGURATION (Required)
# --------------------------------------------
# Get these from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Supabase Project URL
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to use in client-side code)
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (ONLY for backend/seed scripts - NEVER expose in frontend!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# LEGACY API CONFIGURATION (Optional - for gradual migration)
# --------------------------------------------
# If you're doing a gradual migration, you can keep the old API URL
# REACT_APP_API_URL=https://nogahubautomation-production.up.railway.app/api

# --------------------------------------------
# APPLICATION CONFIGURATION
# --------------------------------------------
# Node environment
NODE_ENV=development

# --------------------------------------------
# USER AUTHENTICATION (Required)
# --------------------------------------------
# Format: email:password:role (comma-separated)
# Roles: admin or user
REACT_APP_USERS=admin@nogahub.com:admin123:admin,nadeem@nogahub.com:Nadeem123:admin,issa@nogahub.com:Issa123:admin,kareem@nogahub.com:Kareem123:user,ammar@nogahub.com:Ammar123:user

# --------------------------------------------
# VERCEL DEPLOYMENT (Optional)
# --------------------------------------------
# These are automatically set by Vercel, but you can override them
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=nogahub-automation.vercel.app

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Create a Supabase project at https://app.supabase.com
#
# 3. Get your Supabase credentials:
#    - Go to Project Settings > API
#    - Copy the Project URL to REACT_APP_SUPABASE_URL
#    - Copy the anon/public key to REACT_APP_SUPABASE_ANON_KEY
#    - Copy the service_role key to SUPABASE_SERVICE_ROLE_KEY (for seed scripts only)
#
# 4. Run database migrations:
#    - Install Supabase CLI: npm install -g supabase
#    - Link your project: supabase link --project-ref your-project-id
#    - Push migrations: supabase db push
#
# 5. Seed initial data:
#    - Equipment is seeded via migration (automatic)
#    - Users: node scripts/seed-users.js
#
# 6. Start the development server:
#    npm start
